@project {
    name: "tbdflow-ui"
    version: "0.1.0"
    license: "MIT"
    entry: "src/main.hc"
}

@dependencies {
}

@description {
    summary: "UI for tbdflow"
    author: "@cladam"
    homepage: "https://cladam.github.io/projects/tbdflow/"
    repository: "https://github.com/cladam/tbdflow-ui"
}

@koka {
    include: "src"
    flags: "--cclinkopts=-Llib --cclinkopts=-L/opt/homebrew/opt/sdl2/lib --cclib=imgui_hica --cclib=SDL2 --cclinkopts=-lc++ --cclinkopts=-framework --cclinkopts=OpenGL"
}
